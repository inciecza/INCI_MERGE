{
    "CRS.ObjectNameSuffix": "_Inc",
    "CRS.OnSaveAlFileAction": "Reorganize",
    "CRS.DisableDefaultAlSnippets": true,
    "CRS.RenameWithGit": true,
    "CRS.FileNamePattern": "<ObjectNameShort>.<ObjectTypeShortPascalCase>.al",
    "CRS.FileNamePatternExtensions": "<ObjectNameShort>.<ObjectTypeShortPascalCase>.al",
    "CRS.FileNamePatternPageCustomizations": "<ObjectNameShort>.<ObjectTypeShortPascalCase>.al",
    "al.enableCodeAnalysis": false,
    "al.codeAnalyzers": [
        "${AppSourceCop}",
        "${CodeCop}"
        //"${PerTenantExtensionCop}"
    ],
    "al.assemblyProbingPaths": [
        "./.netpackages",
        "C:/Windows/assembly/",
        "C:/Program Files/Reference Assemblies/Microsoft/Framework/v3.5/",
        "C:/Program Files/Microsoft Dynamics 365 Business Central/200/Service/Add-ins/"
    ],
    "files.exclude": {
        ".vscode/keybindings.json": true,
        ".vscode/tasks.json": true,
        ".vscode/extensions.json": true,
        ".vscode/al.code-snippets": true,
        ".vscode/rad.json": true,
        ".gitignore": true
    },
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "files.autoSave": "off",
    "plantuml.diagramsRoot": "docs/res/diagrams",
    "plantuml.exportOutDir": "docs/res/diagrams",
    "plantuml.exportSubFolder": false,
    "plantuml.exportFormat": "png",
    "plantuml.render": "PlantUMLServer",
    "plantuml.server": "https://www.plantuml.com/plantuml",
    "todohighlight.include": [
        "**/*.js",
        "**/*.jsx",
        "**/*.ts",
        "**/*.tsx",
        "**/*.html",
        "**/*.php",
        "**/*.css",
        "**/*.scss",
        "**/*.al",
        "**/*.ps1"
    ],
    "todohighlight.isEnable": true,
    "cSpell.words": [
        "alpackages",
        "bitbucket",
        "codeunit",
        "featureflags",
        "jira"
    ],
    "gitlens.codeLens.enabled": false,
    "gitlens.statusBar.enabled": false,
    "al.compilationOptions": {

    }
}